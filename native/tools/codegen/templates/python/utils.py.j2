            f"FramingFromIntentResult(dimensions={self.dimensions!r}, "
            f"anchor_point={self.anchor_point!r}, "
            f"protection_dimensions={self.protection_dimensions!r}, "
            f"protection_anchor_point={self.protection_anchor_point!r})"
        )
