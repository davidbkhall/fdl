/** Resolve dimensions from a geometry path string. */
export function getDimensionsFromPath(
  canvas: CanvasType,
  framing: FDType,
  path: string,
  required = true,
): DimensionsFloat | null {
  if (!path || path === 'none') {
    return new DimensionsFloat(0, 0);
  }
  const addon = getAddon();
  const cPath = GEOMETRY_PATH_TO_C.get(path as GeometryPath);
  if (cPath === undefined) {
    throw new Error(`Unsupported source path: ${path}`);
  }
  const result = addon.fdl_resolve_geometry_layer(
    (canvas as any)._handle,
    (framing as any)._handle,
    cPath,
  ) as { _return: number; dims: { width: number; height: number }; anchor: { x: number; y: number } };
  if (result._return === 1) {
    if (required) {
      throw new Error(
        `Template references '${path}' but the source does not have the referenced data defined.`,
      );
    }
    return null;
  }
  if (result._return < 0) {
    throw new Error(`Unsupported source path: ${path}`);
  }
  return new DimensionsFloat(result.dims.width, result.dims.height);
}

/** Resolve anchor point from a geometry path string. */
export function getAnchorFromPath(
  canvas: CanvasType,
  framing: FDType,
  path: string,
): PointFloat {
  if (!path || path === 'none' || path === 'canvas.dimensions') {
    return new PointFloat(0, 0);
  }
  const addon = getAddon();
  const cPath = GEOMETRY_PATH_TO_C.get(path as GeometryPath);
  if (cPath === undefined) {
    throw new Error(`Unsupported source path for anchor point: ${path}`);
  }
  const result = addon.fdl_resolve_geometry_layer(
    (canvas as any)._handle,
    (framing as any)._handle,
    cPath,
  ) as { _return: number; dims: { width: number; height: number }; anchor: { x: number; y: number } };
  if (result._return === 1 || result._return < 0) {
    return new PointFloat(0, 0);
  }
  return new PointFloat(result.anchor.x, result.anchor.y);
}

