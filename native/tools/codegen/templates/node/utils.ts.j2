      result.protection_anchor_point.x,
      result.protection_anchor_point.y,
    );
  }
  return {
    dimensions: dims,
    anchorPoint: anchor,
    protectionDimensions: protDims,
    protectionAnchorPoint: protAnchor,
  };
}
