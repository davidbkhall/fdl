  const rs = rounding ?? getRounding();
  const result = addon.fdl_compute_framing_from_intent(
    { width: canvasDims.width, height: canvasDims.height },
    { width: workingDims.width, height: workingDims.height },
    squeeze,
    { width: aspectRatio.width, height: aspectRatio.height },
    protection,
    toRoundStrategy(rs),
  ) as {
    dimensions: { width: number; height: number };
    anchor_point: { x: number; y: number };
    has_protection: number;
    protection_dimensions: { width: number; height: number };
    protection_anchor_point: { x: number; y: number };
  };
  const dims = new DimensionsFloat(
    result.dimensions.width,
    result.dimensions.height,
  );
  const anchor = new PointFloat(
    result.anchor_point.x,
    result.anchor_point.y,
  );
