/** Compute a framing decision from a framing intent without needing existing handles. */
export function computeFramingFromIntent(
  canvasDims: DimensionsFloat,
  workingDims: DimensionsFloat,
  squeeze: number,
  aspectRatio: DimensionsInt,
  protection: number,
  rounding: RoundStrategy | null = null,
): FramingFromIntentResult {
